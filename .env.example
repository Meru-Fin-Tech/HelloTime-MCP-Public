# HelloTime Public MCP Server — environment variables
#
# This is a public, read-only MCP server. There are NO secrets, NO database,
# NO API keys — only transport configuration. Copy this file to `.env` only
# if you need to override the defaults for local development. In production
# (Docker) the defaults below are baked into the image.
#
# Anything beyond these three variables is a code change, not config.

# HTTP listener port. The Docker image exposes 8080.
PORT=8080

# HTTP listener host. 0.0.0.0 binds all interfaces — required behind a
# load balancer. Use 127.0.0.1 for loopback-only local dev.
HOST=0.0.0.0

# Node runtime mode. Production strips dev tooling and disables verbose errors.
NODE_ENV=production
