# HelloTime Public MCP Server — environment variables
#
# This is a public, read-only MCP server: NO database, NO customer data. The
# only sensitive value is the optional GA4 analytics API secret below — keep
# a real one out of git. Copy this file to `.env` to override defaults for
# local development; in production (Docker) the transport defaults are baked
# into the image and the GA4 vars are injected by the deploy job.

# --- Transport -------------------------------------------------------------

# HTTP listener port. The Docker image exposes 8080.
PORT=8080

# HTTP listener host. 0.0.0.0 binds all interfaces — required behind a
# load balancer. Use 127.0.0.1 for loopback-only local dev.
HOST=0.0.0.0

# Node runtime mode. Production strips dev tooling and disables verbose errors.
NODE_ENV=production

# --- Analytics (optional) --------------------------------------------------
#
# Layer-2 server-side usage telemetry: anonymous session / tool-call counts
# sent to GA4 via the Measurement Protocol. See src/analytics.ts and the
# strategy doc (marketing-strategy → strategy/73-MCP-Analytics-Attribution-
# Strategy.md).
#
# BOTH variables must be set for telemetry to activate. Leave EITHER blank —
# the default — and the server runs with analytics fully disabled: no
# outbound calls, no new required config.
#
# GA4_API_SECRET is a write-only Measurement Protocol secret (it cannot read
# analytics data back) but it is still a secret — never commit a real value.

# GA4 Data Stream Measurement ID, e.g. G-XXXXXXXXXX
GA4_MEASUREMENT_ID=

# GA4 Measurement Protocol API secret
# (GA4 Admin -> Data Streams -> Measurement Protocol API secrets).
GA4_API_SECRET=
