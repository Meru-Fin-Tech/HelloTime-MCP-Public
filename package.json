{
  "name": "hellotime-mcp-public",
  "version": "0.1.2",
  "description": "Public read-only MCP server exposing HelloTime plans, features, country support, and payroll capabilities to AI agents.",
  "license": "MIT",
  "author": "HelloTime <hello@hellotime.app>",
  "homepage": "https://hellotime.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/Meru-Fin-Tech/HelloTime-MCP-Public.git"
  },
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "hellotime-mcp-public": "dist/stdio.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/http.js",
    "start:stdio": "node dist/stdio.js",
    "dev": "tsx watch src/http.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "test": "node --test --import tsx test/*.test.ts",
    "lint": "tsc --noEmit",
    "audit:public-data": "node --import tsx scripts/audit-public-data.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.18.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hellotime",
    "time-tracking",
    "timesheets",
    "payroll",
    "ai-agent",
    "anthropic",
    "claude"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ]
}
